# Окружение
NODE_ENV=development

# Публичный базовый URL (для metadataBase, SEO, ссылок, auth-клиента)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth — https://www.better-auth.com/docs/installation
# Секрет: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials
# Создать "OAuth client ID" (тип Web application).
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# (для прода: https://ideapick.ru/api/auth/callback/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP — отправка писем magic link (почта Timeweb, support@ideapick.ru).
# Если SMTP_USER/SMTP_PASSWORD заданы, письма реально отправляются (в т.ч. в dev).
# Если пусты — в dev ссылка для входа печатается в консоль сервера.
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_USER=support@ideapick.ru
SMTP_PASSWORD=
EMAIL_FROM=Ideapick <support@ideapick.ru>

# PostgreSQL
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME
# Включить SSL для подключения к БД (true — для удалённой БД, пусто/false — для localhost)
DATABASE_SSL=

# ЮKassa — https://yookassa.ru → Настройки → Магазин (shopId + секретный ключ).
# Если переменные пустые — пополнение работает в локальном test-режиме
# (платёж имитируется без обращения к API ЮKassa). Для прода — обязательны.
# Вебхук в личном кабинете ЮKassa: <APP_URL>/api/wallet/yookassa/webhook
# (события payment.succeeded и payment.canceled).
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# DeepSeek — AI-анализ идей (https://platform.deepseek.com → API Keys).
# Если переменная пустая — анализ работает в локальном моковом режиме
# (отчёт генерируется детерминированной заглушкой без обращения к API).
DEEPSEEK_API_KEY=